// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Intake {
  id           String   @id @default(cuid())
  name         String
  passwordHash String
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  pastries     Pastry[]
}

model Pastry {
  id        String   @id @default(cuid())
  name      String
  intakeId  String
  intake    Intake   @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  lessons   Lesson[]
}

model Lesson {
  id             String    @id @default(cuid())
  pastryId       String
  pastry         Pastry    @relation(fields: [pastryId], references: [id], onDelete: Cascade)
  title          String
  pdfUrl         String
  order          Int       @default(0)
  viewCount      Int       @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
}

model RecipeCategory {
  id      String   @id @default(cuid())
  name    String   @unique
  recipes Recipe[]
}

model Recipe {
  id             String          @id @default(cuid())
  name           String
  categoryId     String?
  category       RecipeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pdfUrl         String
  viewCount      Int             @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime        @default(now())
}
